        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(conflict_resolution_duration_ms_bucket{region=\"$region\"}[5m])) by (le, conflict_type))",
          "legendFormat": "P50 - {{conflict_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(conflict_resolution_duration_ms_bucket{region=\"$region\"}[5m])) by (le, conflict_type))",
          "legendFormat": "P95 - {{conflict_type}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(conflict_resolution_duration_ms_bucket{region=\"$region\"}[5m])) by (le, conflict_type))",
          "legendFormat": "P99 - {{conflict_type}}",
          "refId": "C"
        }
      ],
      "title": "Conflict Resolution Duration",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
