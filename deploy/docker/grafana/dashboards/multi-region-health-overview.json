            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 1,
                  "text": "Unavailable"
                },
                "1": {
                  "color": "green",
                  "index": 0,
                  "text": "Available"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
