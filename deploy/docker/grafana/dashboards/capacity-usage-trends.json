    {
      "datasource": "Prometheus",
      "description": "Resource collection success rate",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "id": 5,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "sum(rate(capacity_collection_success_total{resource_type=\"$resource_type\", region_id=\"$region_id\"}[5m])) / (sum(rate(capacity_collection_success_total{resource_type=\"$resource_type\", region_id=\"$region_id\"}[5m])) + sum(rate(capacity_collection_errors_total{resource_type=\"$resource_type\", region_id=\"$region_id\"}[5m])))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "title": "Collection Success Rate",
      "type": "gauge"
    },
