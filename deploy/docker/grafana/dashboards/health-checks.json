              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["sum", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "rate(health_check_failures_total{service=\"$service\"}[5m])",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ],
      "title": "Health Check Failure Rate - $service",
      "type": "timeseries"
    }
  ],
